RewriteEngine On

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^ciditpy\.org [NC]
RewriteRule ^(.*)$ https://www.ciditpy.org/$1 [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# =============================================
# WordPress to Astro redirects
# =============================================

# --- Pages with direct equivalents ---
RewriteRule ^proyecto-covida/?$ /proyectos/covida/ [R=301,L]
RewriteRule ^proyectos-cidit/proteia/?$ /proyectos/proteia/ [R=301,L]
RewriteRule ^proyectos-cidit/cofar/?$ /proyectos/cofar/ [R=301,L]

# --- GuaranIA: archive subdomain for forms ---
RewriteRule ^proyectos-cidit/guarania/postulacion/?$ https://archivo.ciditpy.org/proyectos-cidit/guarania/postulacion/ [R=301,L]
RewriteRule ^proyectos-cidit/guarania/ficha-del-donante/?$ https://archivo.ciditpy.org/proyectos-cidit/guarania/ficha-del-donante/ [R=301,L]

# --- GuaranIA main page (after specific sub-paths above) ---
RewriteRule ^proyectos-cidit/guarania/?$ /proyectos/guarania/ [R=301,L]
RewriteRule ^proyectos-cidit/?$ /proyectos/ [R=301,L]

# --- Pages without direct equivalents ---
RewriteRule ^servicios/?$ /cursos/ [R=301,L]
RewriteRule ^noticias/?$ /publicaciones/ [R=301,L]
RewriteRule ^acceso-cursos/?$ /cursos/ [R=301,L]
RewriteRule ^inscripciones/?$ /contacto/ [R=301,L]

# --- Events custom post type ---
RewriteRule ^eventos/ /cursos/ [R=301,L]

# --- Publications custom post type ---
RewriteRule ^cidit_publicaciones/ /publicaciones/ [R=301,L]

# --- Old project placeholders ---
RewriteRule ^proyectos/proyecto- /proyectos/ [R=301,L]
RewriteRule ^proyectos/nuevo-proyecto/?$ /proyectos/ [R=301,L]

# --- Taxonomy pages ---
RewriteRule ^category/cursos/?$ /cursos/ [R=301,L]
RewriteRule ^category/ /publicaciones/ [R=301,L]
RewriteRule ^tag/ /publicaciones/ [R=301,L]

# --- Blog posts (date-based URLs) ---
RewriteRule ^20[0-9]{2}/ /publicaciones/ [R=301,L]

# --- WordPress sitemap redirects ---
RewriteRule ^wp-sitemap /sitemap-index.xml [R=301,L]
