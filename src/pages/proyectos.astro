---
import MainLayout from "../layouts/mainLayout.astro";
import { getSEO } from "../data/seoData";

const seo = getSEO("/proyectos");

import Hero from "../components/projects/Hero.tsx";
import SocialInnovation from "../components/projects/SocialInnovation.tsx";
import SocialInclusion from "../components/projects/SocialInclusion.tsx";
import ArtificialIntelligence from "../components/projects/ArtificialIntelligence.tsx";
import OtherProjects from "../components/projects/OtherProjects.tsx";
---

<MainLayout title={seo.title} description={seo.description} ogImage={seo.ogImage}>
	<Hero />
	<SocialInnovation />
	<ArtificialIntelligence />
	<SocialInclusion />
	<OtherProjects />
</MainLayout>
